# ═══════════════════════════════════════════════════════════════════════════════
# CredFlow — Environment Variables
# Copy this to .env.local for local dev and fill in your values.
# In Vercel: add each variable under Settings → Environment Variables.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Supabase (Required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ─── Security (Required in production) ────────────────────────────────────────
# Random string for authenticating watchdog cron requests.
# Generate with: openssl rand -hex 32
#
# ⚠️  VERCEL DEPLOYMENT NOTE:
# vercel.json references this as @cron_secret using Vercel's env var syntax.
# You MUST add CRON_SECRET in Vercel Dashboard → Settings → Environment Variables.
# If it is missing there, Vercel sends the literal string "@cron_secret" as the
# header and the watchdog will reject every scheduled run with 401 Unauthorized.
# Check Vercel function logs under /api/watchdog to confirm it's running.
CRON_SECRET=

# ─── AI / Anthropic (Required for AI features) ────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Availity (Optional — for eligibility checks) ─────────────────────────────
AVAILITY_CLIENT_ID=
AVAILITY_CLIENT_SECRET=

# ─── Practice Info (Optional — used by eligibility API) ───────────────────────
PRACTICE_NAME=
