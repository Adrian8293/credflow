# ═══════════════════════════════════════════════════════════════════════════════
# CredFlow — Environment Variables
# Copy this to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Supabase (Required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ─── Security (Required in production) ────────────────────────────────────────
# Random string for authenticating cron job requests (watchdog endpoint)
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── AI / Anthropic (Required for AI features) ────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Availity (Optional — for eligibility checks) ─────────────────────────────
AVAILITY_CLIENT_ID=
AVAILITY_CLIENT_SECRET=

# ─── Practice Info (Optional — used by eligibility API) ───────────────────────
PRACTICE_NAME=
